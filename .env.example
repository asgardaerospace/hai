# ── Contact form (Resend) ─────────────────────────────────────────────
# Create a free API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form submissions are delivered.
# Defaults to info@haiaero.com if unset.
CONTACT_TO_EMAIL=info@haiaero.com

# The "from" address. For production, verify haiaero.com in Resend
# (https://resend.com/domains) and use an address on that domain, e.g.
# "Hemisphere Aerospace <noreply@haiaero.com>".
# If unset, falls back to Resend's shared testing sender, which only
# delivers to the Resend account owner's own email.
CONTACT_FROM_EMAIL="Hemisphere Aerospace <onboarding@resend.dev>"
